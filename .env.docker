# Windscribe Credentials (REQUIRED)
WINDSCRIBE_USERNAME=your_windscribe_email@example.com
WINDSCRIBE_PASSWORD=your_windscribe_password

# Trading Bot Config (REQUIRED)
PRIVATE_KEY=your_wallet_private_key_here

# Trading Bot Options (OPTIONAL)
COPYTRADE_MARKETS=btc
COPYTRADE_SHARES=5
COPYTRADE_MAX_BUY_COUNTS_PER_SIDE=5
SIMULATION_MODE=false

# Logging (OPTIONAL)
LOG_DIR=/app/logs
LOG_FILE_PREFIX=bot
